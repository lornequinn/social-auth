{
    "name": "lornequinn/social-auth",
    "description": "Config-driven Socialite OAuth client for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Lorne Quinn",
            "email": "lorne@lornequinn.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/socialite": "^5.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "LorneQuinn\\SocialAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LorneQuinn\\SocialAuth\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LorneQuinn\\SocialAuth\\SocialAuthServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
